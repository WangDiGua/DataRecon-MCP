# 复制为服务器上的 .env（不要提交到 Git）
# cp .env.production.example .env && nano .env

# ========== MySQL（必填；账号仅需 SELECT） ==========
MYSQL_HOST=YOUR_DB_HOST
MYSQL_PORT=3306
MYSQL_USER=YOUR_READONLY_USER
MYSQL_PASSWORD=YOUR_STRONG_DB_PASSWORD
# 可选：默认库名，不填则工具里用 db_name 指定
MYSQL_DATABASE=

# ========== 查询与内存上限（可按业务调整） ==========
MAX_QUERY_ROWS=200
MAX_EXECUTION_TIME=5000
MAX_EXPLAIN_ROWS=1000000
MAX_SESSION_ROWS=5000
MAX_SESSION_BYTES=10485760

# ========== 传输：服务器上请用 http-sse 或 websocket ==========
TRANSPORT_TYPE=http-sse

# HTTP（http-sse）
HTTP_PORT=3847
HTTP_HOST=0.0.0.0
# 生产环境建议写前端域名，不要用 *
# 例：https://your-app.example.com
CORS_ORIGIN=https://YOUR_FRONTEND_ORIGIN

# WebSocket（若用 TRANSPORT_TYPE=websocket）
WS_PORT=3848
WS_HOST=0.0.0.0

# ========== 认证：公网必须开启 jwt 或 apikey，不要长期 none ==========
AUTH_TYPE=apikey
# apikey 模式：请求头 X-API-Key 或 Authorization: Bearer <API_KEY>
API_KEY=YOUR_LONG_RANDOM_API_KEY
# jwt 模式时改用 AUTH_TYPE=jwt 并填写：
# JWT_SECRET=YOUR_LONG_RANDOM_JWT_SECRET

# ========== 限流（HTTP） ==========
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ========== 可选：隐藏部分库名（逗号分隔） ==========
# DATASOURCE_DENYLIST=internal,backup_db
